{
  "name": "pidevagentai",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "verify:env": "node -e \"const fs=require('fs'); if(!fs.existsSync('.env')){ console.error('ERREUR: fichier .env absent. Copiez .env.example vers .env.'); process.exit(1); } const env=fs.readFileSync('.env','utf8'); const ok=env.split(/\\r?\\n/).some(l=>{const t=l.trim(); return (t.startsWith('MONGO_URI=')&&t.length>10)||(t.startsWith('MONGODB_URI=')&&t.length>12);}); if(!ok){ console.error('ERREUR: MONGO_URI ou MONGODB_URI non défini dans .env (ou valeur vide).'); process.exit(1); } console.log('OK: variables MongoDB présentes dans .env');\"",
    "verify:ml": "curl -sf -X POST http://127.0.0.1:5001/predict -H 'Content-Type: application/json' -d '{\"timeOfDay\":10,\"dayOfWeek\":1,\"suggestionType\":\"coffee\"}' || (echo 'Le service ML ne répond pas sur le port 5001. Lancez-le avec: cd ml_service && uvicorn main:app --port 5001' && exit 1)",
    "verify:backend": "curl -sf http://localhost:3000/ || (echo 'Le backend Nest ne répond pas sur le port 3000. Lancez-le avec: npm run start:dev' && exit 1)",
    "verify:all": "npm run verify:env && npm run verify:ml && npm run verify:backend && echo '' && echo 'Tous les tests de vérification sont passés.'",
    "obs:up": "bash scripts/observability-up-check.sh",
    "obs:down": "docker compose -f docker-compose.observability.yml down",
    "k8s:bootstrap": "bash scripts/k8s/bootstrap-kind.sh",
    "k8s:deploy": "bash scripts/k8s/deploy-all.sh",
    "k8s:test": "bash scripts/k8s/test-all.sh"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-ws": "^11.1.12",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/websockets": "^11.1.12",
    "axios": "^1.13.5",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cors": "^2.8.6",
    "express-rate-limit": "^8.3.2",
    "google-auth-library": "^9.14.0",
    "handlebars": "^4.7.9",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "keycloak-connect": "^26.1.1",
    "mongoose": "^9.3.3",
    "nodemailer": "^6.10.1",
    "openai": "^6.17.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.17.2",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.1",
    "rxjs": "^7.8.1",
    "stripe": "^21.0.1",
    "winston": "^3.19.0",
    "ws": "^8.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.23",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.13.9",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
