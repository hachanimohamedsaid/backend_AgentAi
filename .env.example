# MongoDB hébergé (Atlas) – utilisé par le backend Nest et par le service ML (ml_service).
# Obligatoire : pas de fallback localhost. Même URI pour les deux en prod.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority&appName=<AppName>
# MONGODB_URI=mongodb+srv://...  (alias, utilisé si MONGO_URI n'est pas défini)

# JWT (required for auth)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Préfixe global optionnel (ex. api → routes sous /api/...). Laisser vide pour racine.
# API_PATH_PREFIX=api

# Assignation auto des tâches (dispatch-sprint-emails, autoAssignTasksByProfile) — score minimal 0–100+
# AUTO_ASSIGN_MIN_SCORE=15

# Google Sign-In (optional; if not set, POST /auth/google returns 401)
# Même Client ID que dans la console Google (Web application) et côté Flutter.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# Google OAuth secret — required for the /google-connect/ flow (Gmail + Sheets access)
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Google Connect — AVA Finance Tracker (Gmail + Sheets on behalf of the user)
# Public URL of this backend on Railway — used to build the OAuth callback URL
BACKEND_BASE_URL=https://your-backend.up.railway.app
# N8N instance base URL — used to trigger the setup-sheet webhook after Google Connect
N8N_BASE_URL=https://n8n-production-1e13.up.railway.app
# Shared secret between backend and N8N for server-to-server calls (/users/:id/google-tokens, etc.)
N8N_API_KEY=change-this-to-a-strong-random-secret

# Apple Sign-In (optional; for audience verification of identityToken)
APPLE_CLIENT_ID=your-apple-service-id

# Email – Reset Password (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=avo@resend.dev
# URL de la page « définir nouveau mot de passe » dans l'app Flutter (lien envoyé = cette URL + ?token=...)
FRONTEND_RESET_PASSWORD_URL=https://ton-app.web.app/reset-password/confirm
# URL de la page « vérifier mon email » (lien envoyé après inscription = cette URL + ?token=...)
FRONTEND_VERIFY_EMAIL_URL=https://ton-app.web.app/verify-email

# Talk to buddy – OpenAI (optionnel ; si absent, POST /ai/chat renvoie une réponse factice)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Assignation IA des tâches (dispatch) — Gemini en priorité, puis OpenAI (même OPENAI_API_KEY que ci-dessus possible)
# GEMINI_API_KEY=  (ou GOOGLE_GEMINI_API_KEY)
# GEMINI_MODEL=gemini-2.0-flash

# Advisor – simulation financière (webhook n8n)
ADVISOR_N8N_WEBHOOK_URL=https://n8n-production-1e13.up.railway.app/webhook/a0cd36ce-41f1-4ef8-8bb2-b22cbe7cad6c

# ML Service – URL du service ML (Railway), sans /predict. En dev, si non défini, utilise http://127.0.0.1:5001
ML_SERVICE_URL=https://incredible-determination-production-a7c3.up.railway.app

# Mobility / Smart Reservation (backend uniquement)
MOBILITY_DEFAULT_TIMEZONE=Africa/Tunis
MOBILITY_PROPOSAL_TTL_MINUTES=5
MOBILITY_PROVIDER_WATCHDOG_MINUTES=3
# Real provider dispatch URL (required for real driver data).
# Do not use /mobility/provider-simulator in production when real mode is enabled.
PROVIDER_BASE_URL=
PROVIDER_API_KEY=
PROVIDER_TIMEOUT_MS=10000
PROVIDER_ACCEPT_DRIVER_URL=
PROVIDER_REJECT_DRIVER_URL=
# Set true only if you want hard real-only mode (external provider only).
MOBILITY_ALLOW_LOCAL_FALLBACK=false
# Optional strict mode. Keep false for simulator/in-app flow.
MOBILITY_REQUIRE_REAL_PROVIDER=false
UBER_CLIENT_ID=
UBER_CLIENT_SECRET=
UBER_REDIRECT_URI=
UBER_OAUTH_AUTHORIZE_URL=https://auth.uber.com/oauth/v2/authorize
UBER_OAUTH_TOKEN_URL=https://login.uber.com/oauth/v2/token
UBER_OAUTH_STATE_SECRET=change-this-secret
UBER_QUOTES_API_URL=
UBER_SERVER_TOKEN=
UBER_WEBHOOK_SECRET=
BOLT_API_KEY=
BOLT_API_SECRET=
MAPS_API_KEY=
TRAFFIC_API_KEY=

# Stripe Checkout – abonnements (backend uniquement ; clé secrète jamais dans Flutter)
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_PRICE_MONTHLY=price_xxxxxxxx
STRIPE_PRICE_YEARLY=price_xxxxxxxx
STRIPE_SUCCESS_URL=https://ton-domaine.com/billing/success?plan={PLAN}
STRIPE_CANCEL_URL=https://ton-domaine.com/billing/cancel
STRIPE_SUCCESS_REDIRECT_SCHEME=piagent://

# Social Media Campaign – N8N webhooks
# Webhook called on POST /social-campaign/generate (receives brief, returns per-platform content)
N8N_SOCIAL_WEBHOOK_URL=https://n8n-production-1e13.up.railway.app/webhook/social-campaign
# Webhook called on POST /social-campaign/:id/send (sends campaign report by email)
N8N_EMAIL_AGENT_WEBHOOK_URL=https://your-n8n-instance/webhook/email-agent

# Server port (optional; defaults to 3000)
PORT=3000

# Market Intelligence — Crunchbase (optional; without key, LLM-only / heuristic fallback)
# CRUNCHBASE_API_KEY=
# Optional JSON map: { "FinTech": ["<crunchbase-category-uuid>"], "SaaS": ["..."] }
# MARKET_INTEL_SECTOR_CATEGORY_IDS=
# Optional location UUIDs for funding_rounds search (see Crunchbase Search API docs)
# CRUNCHBASE_LOCATION_EUROPE_UUID=
# CRUNCHBASE_LOCATION_USA_UUID=
# CRUNCHBASE_LOCATION_MENA_UUID=
