        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{job=\"nestjs-backend\",status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"nestjs-backend\"}[5m]))",
          "refId": "A"
        }
      ],
      "title": "HTTP 5xx Error Rate",
      "type": "stat"
    },
